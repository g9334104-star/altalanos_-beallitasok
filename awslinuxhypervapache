# vagy
mkdir -p /share        # D feladatnál

# Csatolás
mount /dev/md0 /web
12.3 Automatikus csatolás beállítása (/etc/fstab)
# UUID lekérdezése
blkid /dev/md0

nano /etc/fstab
Add hozzá a végére:
/dev/md0    /web    btrfs    defaults    0    0
12.4 mdadm konfig mentése
mdadm --detail --scan >> /etc/mdadm/mdadm.conf
update-initramfs -u
