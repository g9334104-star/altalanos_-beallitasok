git clone https…

# Apache újraindítás
systemctl restart apache2

# Tulajdonos beállítás
chown -R www-data:www-data /web/html
chown -R FELHASZNALO:CSOPORT /share/kozos

# Jogosultság
chmod -R 755 /web/html
chmod -R 770 /share/kozos
chmod -R 640 /fajl

# Felhasználó létrehozása
useradd -m FELHASZNALO
echo "FELHASZNALO:Pay" | chpasswd

# Csoport létrehozása + tag hozzáadása
groupadd CSOPORT
usermod -aG CSOPORT FELHASZNALO

# IP konfig
nano /etc/network/interfaces
systemctl restart networking

# SSH kapcsolat
ssh -i kulcs.pem admin@IP

# Fájl kicsomagolás
tar -xzf fajl.tgz
unzip fajl.zip

# Szimbolikus link
ln -s /var/www/html/main.php /var/www/html/index.php

# Fájl törlés
